{
  "name": "ghost-expression",
  "version": "0.0.0",
  "description": "Author and validate expression.md — Ghost's canonical design-language artifact (parse, lint, describe, diff, emit review-command/context-bundle/skill)",
  "license": "Apache-2.0",
  "author": "Block, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/block/ghost.git"
  },
  "homepage": "https://github.com/block/ghost#readme",
  "bugs": {
    "url": "https://github.com/block/ghost/issues"
  },
  "keywords": [
    "design-system",
    "expression",
    "design-language",
    "design-tokens",
    "cli"
  ],
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "bin": {
    "ghost-expression": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && cp -r src/skill-bundle dist/skill-bundle",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ghost/core": "workspace:*",
    "cac": "^6.7.14",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
