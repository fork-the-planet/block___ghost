{
  "name": "ghost",
  "private": true,
  "description": "Design drift detection system",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "check": "biome check . && pnpm typecheck && pnpm check:file-sizes",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "fmt": "biome format --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^22.0.0",
    "lefthook": "^2.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
